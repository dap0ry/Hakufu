<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBackground"      Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SidebarBackground"  Color="#111111"/>
    <SolidColorBrush x:Key="CardBackground"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HoverBackground"    Color="#252525"/>
    <SolidColorBrush x:Key="SelectedBackground" Color="#2E2E2E"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="CardBorder"         Color="#2A2A2A"/>
    <SolidColorBrush x:Key="InputBorder"        Color="#333333"/>
    <SolidColorBrush x:Key="DividerBrush"       Color="#222222"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="#AAAAAA"/>
    <SolidColorBrush x:Key="TextMuted"          Color="#666666"/>

    <!-- Accent / Buttons -->
    <SolidColorBrush x:Key="AccentColor"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonBackground"   Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonForeground"   Color="#0A0A0A"/>
    <SolidColorBrush x:Key="ButtonHover"        Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ButtonBorder"       Color="#F0F0F0"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground"  Color="#BB000000"/>

    <!-- Progress -->
    <SolidColorBrush x:Key="ProgressFill"       Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ProgressTrack"      Color="#333333"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarThumb"     Color="#444444"/>
    <SolidColorBrush x:Key="ScrollBarTrack"     Color="Transparent"/>

    <!-- Window chrome -->
    <SolidColorBrush x:Key="TitleBarBackground" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="TitleBarForeground" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="WindowBorder"       Color="#2A2A2A"/>

    <!-- Reader -->
    <SolidColorBrush x:Key="ReaderBackground"   Color="#080808"/>
    <SolidColorBrush x:Key="ReaderBarBackground" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="ReaderForeground"   Color="#F0F0F0"/>

</ResourceDictionary>
