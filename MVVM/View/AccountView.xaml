<UserControl x:Class="Hakufu.MVVM.View.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="CaretBrush"   Value="{DynamicResource AccentColor}"/>
        </Style>

        <Style x:Key="FormPassword" TargetType="PasswordBox">
            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <Style x:Key="BackButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="T"
                                   Text="← Volver"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="T" Property="Foreground"
                                        Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="45*"/>
            <ColumnDefinition Width="55*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT — branding ═══ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Viewbox Grid.Row="0" Stretch="Uniform"
                         HorizontalAlignment="Left"
                         Margin="56,0,40,0"
                         MaxWidth="320">
                    <StackPanel Width="320">
                        <TextBlock FontFamily="Segoe UI" TextTrimming="None">
                            <Run Text="HAKU"
                                 FontSize="80" FontWeight="Black"
                                 Foreground="{DynamicResource TextPrimary}"/>
                            <Run Text="FU"
                                 FontSize="80" FontWeight="Black"
                                 Foreground="{DynamicResource AccentColor}"/>
                        </TextBlock>
                        <Rectangle Height="4" Width="60"
                                   HorizontalAlignment="Left"
                                   Fill="{DynamicResource AccentColor}"
                                   Margin="2,6,0,0"/>
                        <TextBlock Text="Crea tu cuenta o inicia sesión"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="2,10,0,0"/>
                    </StackPanel>
                </Viewbox>

                <TextBlock Grid.Row="1"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="56,0,0,48">
                    <Hyperlink NavigateUri="https://danielpozarivera.es/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource TextMuted}"
                               TextDecorations="None">
                        por Daniel Poza Rivera
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══ RIGHT — formulario ═══ -->
        <Grid Grid.Column="1" Background="{DynamicResource AppBackground}">

            <!-- Volver -->
            <Button Style="{StaticResource BackButton}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="36,28,0,0"
                    Command="{Binding BackCommand}"/>

            <!-- Formulario centrado -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="340">

                <!-- ── Tabs ── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,40">

                    <!-- Login tab -->
                    <Button Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="0" Margin="0,0,36,0"
                            Command="{Binding SwitchToLoginCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Light">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                        <Setter Property="Text"       Value="Iniciar sesión"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoginTab}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Rectangle Height="2" HorizontalAlignment="Left"
                                       Fill="{DynamicResource AccentColor}" Margin="0,6,0,0">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Width" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoginTab}" Value="True">
                                                <Setter Property="Width" Value="40"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </StackPanel>
                    </Button>

                    <!-- Register tab -->
                    <Button Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="0"
                            Command="{Binding SwitchToRegisterCommand}">
                        <StackPanel>
                            <TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Light">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                        <Setter Property="Text"       Value="Registrarse"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRegisterTab}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Rectangle Height="2" HorizontalAlignment="Left"
                                       Fill="{DynamicResource AccentColor}" Margin="0,6,0,0">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Width" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRegisterTab}" Value="True">
                                                <Setter Property="Width" Value="40"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- ── LOGIN FORM ── -->
                <StackPanel Visibility="{Binding IsLoginTab,
                                Converter={StaticResource BoolToVisibility}}">

                    <TextBlock Style="{StaticResource FieldLabel}" Text="NOMBRE DE USUARIO"/>
                    <TextBox Style="{StaticResource FormInput}"
                             Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="CONTRASEÑA"/>
                    <PasswordBox x:Name="LoginPwBox"
                                 Style="{StaticResource FormPassword}"
                                 Margin="0,0,0,28"
                                 PasswordChanged="LoginPwBox_PasswordChanged"/>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Entrar"
                            HorizontalAlignment="Stretch"
                            Padding="0,13"
                            Command="{Binding LoginCommand}"/>

                </StackPanel>

                <!-- ── REGISTER FORM ── -->
                <StackPanel Visibility="{Binding IsRegisterTab,
                                Converter={StaticResource BoolToVisibility}}">

                    <TextBlock Style="{StaticResource FieldLabel}" Text="NOMBRE DE USUARIO"/>
                    <TextBox Style="{StaticResource FormInput}"
                             Text="{Binding RegUsername, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="CORREO ELECTRÓNICO"/>
                    <TextBox Style="{StaticResource FormInput}"
                             Text="{Binding RegEmail, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="CONTRASEÑA"/>
                    <PasswordBox x:Name="RegPwBox"
                                 Style="{StaticResource FormPassword}"
                                 Margin="0,0,0,16"
                                 PasswordChanged="RegPwBox_PasswordChanged"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="REPETIR CONTRASEÑA"/>
                    <PasswordBox x:Name="RegPwConfirmBox"
                                 Style="{StaticResource FormPassword}"
                                 Margin="0,0,0,28"
                                 PasswordChanged="RegPwConfirmBox_PasswordChanged"/>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Crear cuenta"
                            HorizontalAlignment="Stretch"
                            Padding="0,13"
                            Command="{Binding RegisterCommand}"/>

                </StackPanel>

                <!-- ── Error ── -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E05C5C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Margin="0,16,0,0"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource NullToVisibility}}"/>

                <!-- ── Loading ── -->
                <TextBlock Text="Cargando…"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Visibility="{Binding IsLoading,
                               Converter={StaticResource BoolToVisibility}}"/>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
