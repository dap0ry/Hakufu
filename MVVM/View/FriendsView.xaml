<UserControl x:Class="Hakufu.MVVM.View.FriendsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel"
             xmlns:conv="clr-namespace:Hakufu.Converters">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER (misma plantilla que ProfileView) ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,22,40,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding BackCommand}"
                        Margin="0,0,24,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="AMIGOS"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="Conecta con otros lectores"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>

                <!-- Enviar solicitud -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Enviar solicitud"
                            Padding="18,9"
                            Command="{Binding SendRequestCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ NO SESIÓN ═══ -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}">
            <TextBlock Text="—" FontSize="36"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Inicia sesión para ver tus amigos"
                       FontSize="14" Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center"/>
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Iniciar sesión"
                    Command="{Binding NavLoginCommand}"
                    HorizontalAlignment="Center"
                    Padding="24,11" Margin="0,20,0,0"/>
        </StackPanel>

        <!-- ═══ CONTENIDO (con sesión) ═══ -->
        <ScrollViewer Grid.Row="1"
                      Padding="40,36,40,40"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>

                <!-- Mensaje de estado -->
                <Border CornerRadius="6" Padding="14,10" Margin="0,0,0,24"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="{DynamicResource AccentColor}"/>
                </Border>

                <!-- Cargando -->
                <TextBlock Text="Cargando…"
                           FontSize="12" Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,24"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── SOLICITUDES PENDIENTES ── -->
                <StackPanel Margin="0,0,0,40"
                            Visibility="{Binding HasPendingRequests, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="SOLICITUDES PENDIENTES"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding PendingRequests}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FriendRequestItemViewModel}">
                                <Border Width="168" Margin="0,0,16,16" CornerRadius="12"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="16" Opacity="0.09"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- Info -->
                                        <StackPanel HorizontalAlignment="Center" Margin="16,20,16,16">
                                            <Grid Width="58" Height="58" HorizontalAlignment="Center" Margin="0,0,0,12">
                                                <!-- Foto de perfil -->
                                                <Border CornerRadius="29" ClipToBounds="True"
                                                        Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}">
                                                    <Image Source="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                                <!-- Inicial (fallback) -->
                                                <Border CornerRadius="29"
                                                        Background="{DynamicResource AccentColor}"
                                                        Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}">
                                                    <TextBlock Text="{Binding Initial}"
                                                               FontSize="22" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding From}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="quiere ser tu amigo"
                                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                       TextAlignment="Center" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <!-- Divisor -->
                                        <Rectangle Height="1" Fill="{DynamicResource DividerBrush}"/>
                                        <!-- Botones -->
                                        <StackPanel Margin="12,12,12,12">
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    HorizontalAlignment="Stretch" Padding="0,9"
                                                    Content="✓  Aceptar"
                                                    FontSize="12"
                                                    Command="{Binding AcceptCommand}"
                                                    Margin="0,0,0,7"/>
                                            <Button Style="{StaticResource GhostButton}"
                                                    HorizontalAlignment="Stretch" Padding="0,8"
                                                    Content="✕  Rechazar"
                                                    FontSize="12"
                                                    Foreground="#B05858" BorderBrush="#30B05858"
                                                    Command="{Binding RejectCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Divisor -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,36"
                           Visibility="{Binding HasPendingRequests, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── AMIGOS ── -->
                <TextBlock FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,16">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="AMIGOS"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFriends}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            Visibility="{Binding HasFriends, Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock Text="{Binding Friends.Count}" Visibility="Collapsed"/>
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="Sin amigos todavía"
                                   FontSize="14" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Busca un usuario y envíale una solicitud"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Grid de amigos -->
                <ItemsControl ItemsSource="{Binding Friends}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FriendItemViewModel}">
                            <Border Width="168" Margin="0,0,16,16" CornerRadius="12"
                                    Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="16" Opacity="0.09"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Info -->
                                    <StackPanel HorizontalAlignment="Center" Margin="16,20,16,16">
                                        <Grid Width="58" Height="58" HorizontalAlignment="Center" Margin="0,0,0,12">
                                            <!-- Foto de perfil -->
                                            <Border CornerRadius="29" ClipToBounds="True"
                                                    Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}">
                                                <Image Source="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <!-- Inicial (fallback) -->
                                            <Border CornerRadius="29"
                                                    Background="{DynamicResource DividerBrush}"
                                                    Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}">
                                                <TextBlock Text="{Binding Initial}"
                                                           FontSize="22" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentColor}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Username}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Amigo"
                                                   FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                   TextAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <!-- Divisor -->
                                    <Rectangle Height="1" Fill="{DynamicResource DividerBrush}"/>
                                    <!-- Botones -->
                                    <StackPanel Margin="12,12,12,12">
                                        <Button Style="{StaticResource GhostButton}"
                                                HorizontalAlignment="Stretch" Padding="0,9"
                                                Content="Ver perfil  →"
                                                FontSize="12"
                                                Command="{Binding ViewProfileCommand}"
                                                Margin="0,0,0,7"/>
                                        <Button Style="{StaticResource GhostButton}"
                                                HorizontalAlignment="Stretch" Padding="0,8"
                                                Content="✕  Eliminar"
                                                FontSize="12"
                                                Foreground="#B05858" BorderBrush="#30B05858"
                                                Command="{Binding RemoveCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
