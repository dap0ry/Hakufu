<UserControl x:Class="Hakufu.MVVM.View.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,24,40,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,24,0"/>
                <TextBlock Grid.Column="1" Text="AYUDA"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ BODY ═══ -->
        <ScrollViewer x:Name="sv" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="{Binding ViewportHeight, ElementName=sv}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="40,40,40,40">

                <!-- Section intro -->
                <Grid Margin="0,0,0,36" MaxWidth="640" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Atajos de teclado"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Disponibles en el lector de manga"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="⌨"
                               FontSize="52"
                               Foreground="{DynamicResource DividerBrush}"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0"/>
                </Grid>

                <!-- Shortcuts grid - two columns of cards -->
                <ItemsControl ItemsSource="{Binding Shortcuts}" MaxWidth="640" HorizontalAlignment="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ShortcutEntry}">
                            <Border Margin="0,0,16,16"
                                    Style="{StaticResource Card}"
                                    Padding="20,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Key cap -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource HoverBackground}"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,12">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" ShadowDepth="1"
                                                              BlurRadius="3" Opacity="0.12" Direction="270"/>
                                        </Border.Effect>
                                        <TextBlock Text="{Binding Keys}"
                                                   FontFamily="Consolas"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>

                                    <!-- Description -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
