<UserControl x:Class="Hakufu.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- ── Creative nav-item: divisor + número ghost + flecha hover ── -->
        <Style x:Key="HomeNavItem" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,18,32,18"
                                Background="Transparent">
                            <Grid>
                                <!-- Ghost number — huge, barely visible -->
                                <TextBlock x:Name="Ghost"
                                           Text="{Binding Tag,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="88" FontWeight="Black"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Opacity="0.04"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           IsHitTestVisible="False"/>

                                <!-- Content: number label + name -->
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Opacity="0.45"
                                                  Margin="0,0,0,0"/>

                                <!-- Arrow ─ appears on hover -->
                                <TextBlock x:Name="Arrow"
                                           Text="→"
                                           FontSize="18"
                                           FontFamily="Segoe UI"
                                           Foreground="{DynamicResource AccentColor}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Opacity="0"/>

                                <!-- Accent underline ─ expands on hover -->
                                <Rectangle x:Name="Underline"
                                           Height="2"
                                           Fill="{DynamicResource AccentColor}"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Left"
                                           Width="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Content"   Property="Opacity"  Value="1"/>
                                <Setter TargetName="Arrow"     Property="Opacity"  Value="1"/>
                                <Setter TargetName="Ghost"     Property="Opacity"  Value="0.07"/>
                                <Setter TargetName="Underline" Property="Width"    Value="40"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.65"/>
                                <Setter TargetName="Arrow"   Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>  <!-- Left — nav -->
            <ColumnDefinition Width="45*"/>  <!-- Right — continue reading -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- LEFT  — título + navegación                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- title -->
                    <RowDefinition Height="*"/>      <!-- nav items -->
                    <RowDefinition Height="Auto"/>   <!-- footer -->
                </Grid.RowDefinitions>

                <!-- ── TÍTULO ── -->
                <Viewbox Grid.Row="0" Stretch="Uniform"
                         HorizontalAlignment="Stretch"
                         Margin="40,24,40,0">
                    <StackPanel Width="460">
                        <TextBlock FontFamily="Segoe UI" TextTrimming="None">
                            <Run Text="HAKU"
                                 FontSize="96" FontWeight="Black"
                                 Foreground="{DynamicResource TextPrimary}"/>
                            <Run Text="FU"
                                 FontSize="96" FontWeight="Black"
                                 Foreground="{DynamicResource AccentColor}"/>
                        </TextBlock>
                        <Rectangle Height="4" Width="72"
                                   HorizontalAlignment="Left"
                                   Fill="{DynamicResource AccentColor}"
                                   Margin="2,6,0,0"/>
                        <TextBlock Text="Tu biblioteca de manga"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="2,8,0,0"/>
                    </StackPanel>
                </Viewbox>

                <!-- ── NAV ITEMS ── -->
                <!-- Width="800" asegura que el escalado sea width-constrained → sin centrado horizontal -->
                <Viewbox Grid.Row="1" Stretch="Uniform"
                         HorizontalAlignment="Stretch" VerticalAlignment="Center"
                         Margin="0,16,0,16">
                <StackPanel Width="800">

                    <Button Style="{StaticResource HomeNavItem}"
                            Tag="01"
                            Margin="0,0,0,0"
                            Command="{Binding NavLibraryCommand}">
                        <StackPanel>
                            <TextBlock Text="01"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Biblioteca"
                                       FontSize="46" FontWeight="Light"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HomeNavItem}"
                            Tag="02"
                            Margin="48,0,0,0"
                            Command="{Binding NavProfileCommand}">
                        <StackPanel>
                            <TextBlock Text="02"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Perfil"
                                       FontSize="46" FontWeight="Light"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HomeNavItem}"
                            Tag="03"
                            Margin="16,0,0,0"
                            Command="{Binding NavSettingsCommand}">
                        <StackPanel>
                            <TextBlock Text="03"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Ajustes"
                                       FontSize="46" FontWeight="Light"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HomeNavItem}"
                            Tag="04"
                            Margin="0,0,0,0"
                            Command="{Binding NavHelpCommand}">
                        <StackPanel>
                            <TextBlock Text="04"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Ayuda"
                                       FontSize="46" FontWeight="Light"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HomeNavItem}"
                            Tag="05"
                            Margin="32,0,0,0"
                            Command="{Binding NavUpdatesCommand}">
                        <StackPanel>
                            <TextBlock Text="05"
                                       FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Actualizaciones"
                                       FontSize="46" FontWeight="Light"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
                </Viewbox>

                <!-- ── FOOTER ── -->
                <TextBlock Grid.Row="2"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="56,0,0,48">
                    <Hyperlink NavigateUri="https://danielpozarivera.es/"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource TextMuted}"
                               TextDecorations="None">
                        por Daniel Poza Rivera
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- RIGHT  — continuar leyendo                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{DynamicResource AppBackground}" ClipToBounds="True">

            <!-- Estado vacío -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasLastManga, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="—"
                           FontSize="32"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Sin lectura reciente"
                           Style="{StaticResource SubtitleText}"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Abre Biblioteca para empezar"
                           Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Manga en curso -->
            <Grid Visibility="{Binding HasLastManga, Converter={StaticResource BoolToVisibility}}">

                <!-- Portada difuminada de fondo (decorativa) -->
                <Image Source="{Binding LastMangaCover}"
                       Stretch="UniformToFill"
                       Opacity="0.07"
                       RenderOptions.BitmapScalingMode="LowQuality"/>

                <!-- Degradado sobre el fondo -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#55000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Contenido centrado -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="280">

                    <!-- Portada principal (flotante) -->
                    <Border Width="220" Height="310"
                            CornerRadius="6"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,28">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="0"
                                              BlurRadius="40" Opacity="0.32"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <RotateTransform Angle="-1.5" CenterX="110" CenterY="155"/>
                        </Border.RenderTransform>
                        <Image Source="{Binding LastMangaCover}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- Etiqueta -->
                    <TextBlock Text="CONTINUAR LEYENDO"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Título -->
                    <TextBlock Text="{Binding LastMangaTitle}"
                               FontSize="17"
                               FontWeight="Medium"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimary}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Botón -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Continuar leyendo"
                            HorizontalAlignment="Center"
                            Padding="28,11"
                            Command="{Binding ContinueReadingCommand}"/>

                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
