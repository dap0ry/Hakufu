<UserControl x:Class="Hakufu.MVVM.View.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- continue reading -->
            <RowDefinition Height="*"/>      <!-- collections -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,24,40,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back -->
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,24,0"/>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="BIBLIOTECA"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Collections.Count, StringFormat={}{0} colecciones}"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Normal mode -->
                    <Button Style="{StaticResource GhostButton}"
                            Content="Seleccionar"
                            Padding="16,10"
                            Margin="0,0,12,0"
                            Command="{Binding ToggleSelectionModeCommand}"
                            Visibility="{Binding IsSelectionMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="+ Nueva colección"
                            Padding="20,10"
                            Command="{Binding CreateCollectionCommand}"
                            Visibility="{Binding IsSelectionMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <!-- Selection mode -->
                    <Button Style="{StaticResource GhostButton}"
                            Content="Cancelar"
                            Padding="16,10"
                            Margin="0,0,12,0"
                            Command="{Binding ToggleSelectionModeCommand}"
                            Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="20,10"
                            Command="{Binding DeleteSelectedCommand}"
                            Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibility}}">
                        <Button.Content>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <Run Text="Eliminar ("/>
                                <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTINUAR LEYENDO ═══ -->
        <Border Grid.Row="1"
                Padding="40,20,40,0"
                Visibility="{Binding HasLastManga, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Button Style="{StaticResource IconButton}"
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding ContinueReadingCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cover -->
                        <Border Grid.Column="0" Width="72" Height="100"
                                CornerRadius="6,0,0,6" ClipToBounds="True"
                                Background="{DynamicResource SidebarBackground}">
                            <Image Source="{Binding LastMangaCover}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="CONTINUAR LEYENDO"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding LastMangaTitle}"
                                       FontSize="15" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Arrow -->
                        <TextBlock Grid.Column="2"
                                   Text="→"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,24,0"/>
                    </Grid>
                </Button>
            </Border>
        </Border>

        <!-- ═══ COLECCIONES ═══ -->
        <ScrollViewer Grid.Row="2"
                      Padding="40,28,40,40"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Section label -->
                <TextBlock Text="MIS COLECCIONES"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,20"/>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,40,0,0"
                            Visibility="{Binding Collections.Count, Converter={StaticResource NullToVisibilityInverse}}">
                    <TextBlock Text="—" FontSize="28"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Sin colecciones todavía"
                               Style="{StaticResource SubtitleText}"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Pulsa &quot;+ Nueva colección&quot; para empezar"
                               Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Cards wrap -->
                <ItemsControl ItemsSource="{Binding Collections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CollectionCardViewModel}">
                            <Button Margin="0,0,24,28"
                                    Command="{Binding DataContext.CardClickCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root" Opacity="1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Width="172">
                                    <!-- Stacked cover effect -->
                                    <Grid Width="172" Height="232" Margin="0,0,0,10">
                                        <!-- Back -->
                                        <Border Width="154" Height="218" CornerRadius="6"
                                                Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Panel.ZIndex="0" RenderTransformOrigin="0.5,1.0">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform Angle="-4"/>
                                                    <TranslateTransform X="9" Y="-7"/>
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Image Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverPreviews.Count}" Value="3">
                                                                <Setter Property="Source" Value="{Binding CoverPreviews[2]}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CoverPreviews.Count}" Value="2">
                                                                <Setter Property="Source" Value="{Binding CoverPreviews[1]}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Border>
                                        <!-- Middle -->
                                        <Border Width="160" Height="224" CornerRadius="6"
                                                Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Panel.ZIndex="1" RenderTransformOrigin="0.5,1.0">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform Angle="-2"/>
                                                    <TranslateTransform X="4" Y="-3"/>
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Image Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverPreviews.Count}" Value="2">
                                                                <Setter Property="Source" Value="{Binding CoverPreviews[1]}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CoverPreviews.Count}" Value="1">
                                                                <Setter Property="Source" Value="{Binding CoverPreviews[0]}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Border>
                                        <!-- Front -->
                                        <Border Width="166" Height="228" CornerRadius="6"
                                                Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Panel.ZIndex="2">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" ShadowDepth="0"
                                                                  BlurRadius="18" Opacity="0.20"/>
                                            </Border.Effect>
                                            <Image Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverPreviews.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                                <Image.Source>
                                                    <Binding Path="CoverPreviews[0]">
                                                        <Binding.FallbackValue>{x:Null}</Binding.FallbackValue>
                                                    </Binding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <!-- Selection overlay -->
                                        <Border CornerRadius="6"
                                                Background="{DynamicResource AccentColor}"
                                                Opacity="0.22"
                                                Panel.ZIndex="3"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>
                                        <Border Width="26" Height="26" CornerRadius="13"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,8,8,0"
                                                Background="{DynamicResource AccentColor}"
                                                Panel.ZIndex="4"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="✓" Foreground="White"
                                                       FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Name -->
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               FontWeight="Medium" FontSize="13"
                                               Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Left"/>
                                    <!-- Count -->
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Left"
                                               Margin="0,3,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} manga(s)">
                                                <Binding Path="MangaCount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
