<UserControl x:Class="Hakufu.MVVM.View.MangaPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel">

    <StackPanel MinWidth="380" MaxHeight="480" >
        <TextBlock Text="Elegir manga favorito"
                   Style="{StaticResource SubtitleText}"
                   Margin="0,0,0,16"/>

        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Mangas}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MangaPickerViewModel}">
                        <!-- This DataTemplate is for individual Manga items -->
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Manga list as buttons -->
        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Mangas}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource GhostButton}"
                                HorizontalContentAlignment="Left"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,4"
                                Command="{Binding DataContext.SelectCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Style="{StaticResource GhostButton}"
                Content="Cancelar"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Command="{Binding CancelCommand}"/>
    </StackPanel>
</UserControl>
