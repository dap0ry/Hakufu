<UserControl x:Class="Hakufu.MVVM.View.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel">

    <Grid>

        <!-- ═══ MAIN PROFILE ═══ -->
        <Grid Visibility="{Binding ShowingAllHistory, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="40,24,40,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Content="← Inicio"
                            Command="{Binding GoBackCommand}"
                            Margin="0,0,24,0"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="PERFIL"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Estadísticas y actividad reciente"
                                   Style="{StaticResource CaptionText}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource GhostButton}"
                            Content="Historial completo"
                            Padding="20,10"
                            Command="{Binding ViewAllHistoryCommand}"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" Padding="40,36,40,40" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── COMPLETADOS RECIENTEMENTE ── -->
                    <TextBlock Text="COMPLETADOS RECIENTEMENTE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,16"/>

                    <!-- Empty state -->
                    <TextBlock Text="Todavía no has terminado ningún manga."
                               Style="{StaticResource CaptionText}"
                               Margin="0,0,0,36"
                               Visibility="{Binding HasRecentActivity, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <!-- 3 wide horizontal cards filling the page width -->
                    <ItemsControl ItemsSource="{Binding RecentActivity}"
                                  Margin="0,0,0,40"
                                  Visibility="{Binding HasRecentActivity, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:HistoryEntryViewModel}">
                                <Border Height="120" CornerRadius="10" ClipToBounds="True"
                                        Margin="0,0,16,0"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" ShadowDepth="0"
                                                          BlurRadius="14" Opacity="0.08"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="88"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Cover -->
                                        <Border Grid.Column="0" ClipToBounds="True">
                                            <Image Source="{Binding Cover}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <!-- Info -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,16,0">
                                            <TextBlock Text="COMPLETADO"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Manga.Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="50"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding TimeAgo}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMuted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,36"/>

                    <!-- ── ESTADÍSTICAS ── -->
                    <TextBlock Text="ESTADÍSTICAS"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,20"/>

                    <UniformGrid Columns="3" Margin="0,0,0,40">
                        <!-- Páginas leídas -->
                        <Border Margin="0,0,16,0" CornerRadius="10" Padding="24,22"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="0"
                                                  BlurRadius="14" Opacity="0.07"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding TotalPagesRead, StringFormat={}{0:N0}}"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="páginas leídas"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </Border>

                        <!-- Colección favorita -->
                        <Border Margin="0,0,16,0" CornerRadius="10" Padding="24,22"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="0"
                                                  BlurRadius="14" Opacity="0.07"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="COLECCIÓN FAVORITA"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding FavoriteCollectionName}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"
                                           MaxHeight="52"/>
                            </StackPanel>
                        </Border>

                        <!-- Tiempo total -->
                        <Border CornerRadius="10" Padding="24,22"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="0"
                                                  BlurRadius="14" Opacity="0.07"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding TotalUsageFormatted}"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="tiempo total de uso"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,36"/>

                    <!-- ── PÁGINAS POR COLECCIÓN ── -->
                    <TextBlock Text="PÁGINAS POR COLECCIÓN"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Aún no hay datos de lectura por colección."
                               Style="{StaticResource CaptionText}"
                               Visibility="{Binding HasCollectionStats, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <ItemsControl ItemsSource="{Binding CollectionStats}"
                                  Visibility="{Binding HasCollectionStats, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CollectionStatViewModel}">
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CollectionName}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Bar track + fill -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                        <!-- Track -->
                                        <Border Height="10" CornerRadius="5"
                                                Background="{DynamicResource ProgressTrack}"/>
                                        <!-- Fill -->
                                        <Border Height="10" CornerRadius="5"
                                                Background="{DynamicResource AccentColor}"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentageWidth}">
                                                    <Binding Path="BarPercent"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}"
                                                             Path="ActualWidth"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>

                                    <!-- Page count -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PagesRead, StringFormat={}{0:N0} págs.}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ HISTORIAL COMPLETO ═══ -->
        <Grid Visibility="{Binding ShowingAllHistory, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="40,24,40,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Content="← Perfil"
                            Command="{Binding BackToProfileCommand}"
                            Margin="0,0,24,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="HISTORIAL"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding FullHistory.Count, StringFormat={}{0} entradas}"
                                   Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="40,32,40,40" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FullHistory}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HistoryEntryViewModel}">
                            <StackPanel Width="140" Margin="0,0,20,28">
                                <Border Height="200" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        Margin="0,0,0,10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" ShadowDepth="0"
                                                          BlurRadius="12" Opacity="0.12"/>
                                    </Border.Effect>
                                    <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="{Binding Manga.Title}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding TimeAgo}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
