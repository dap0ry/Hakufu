<UserControl x:Class="Hakufu.MVVM.View.PublicProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel"
             xmlns:conv="clr-namespace:Hakufu.Converters">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,22,40,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Amigos"
                        Command="{Binding BackCommand}"
                        Margin="0,0,24,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="PERFIL PÚBLICO"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ProfileUsername}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CARGANDO ═══ -->
        <TextBlock Grid.Row="1"
                   Text="Cargando perfil…"
                   FontSize="13" Foreground="{DynamicResource TextMuted}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- ═══ ERROR ═══ -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   FontSize="13" Foreground="#E05C5C"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>

        <!-- ═══ CONTENIDO ═══ -->
        <ScrollViewer Grid.Row="1"
                      Padding="40,36,40,40"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel>

                <!-- ── ESTADÍSTICAS ── -->
                <TextBlock Text="ESTADÍSTICAS"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,20"/>

                <UniformGrid Columns="2" Margin="0,0,0,40">
                    <Border Margin="0,0,16,0" CornerRadius="10" Padding="24,22"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="{Binding MangasCount}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="mangas en biblioteca"
                                       FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="10" Padding="24,22"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="{Binding TotalUsage}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="tiempo de lectura"
                                       FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,36"
                           Visibility="{Binding HasReadingSection, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── LEYENDO AHORA + ÚLTIMO TOMO COMPLETADO ── -->
                <Grid Margin="0,0,0,40"
                      Visibility="{Binding HasReadingSection, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEYENDO AHORA -->
                    <StackPanel Grid.Column="0"
                                Visibility="{Binding HasCurrentlyReading, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="LEYENDO AHORA"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,12"/>
                        <Border CornerRadius="10" ClipToBounds="True" Height="110"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" ClipToBounds="True">
                                    <Image Source="{Binding CurrentlyReadingCover,
                                               Converter={StaticResource UrlToImage}}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,20,0">
                                    <TextBlock Text="{Binding CurrentlyReadingTitle}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding ReadingProgress}"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ÚLTIMO TOMO COMPLETADO -->
                    <StackPanel Grid.Column="2"
                                Visibility="{Binding HasLastCompleted, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="ÚLTIMO TOMO COMPLETADO"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,12"/>
                        <Border CornerRadius="10" ClipToBounds="True" Height="110"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" ClipToBounds="True">
                                    <Image Source="{Binding LastCompletedCover,
                                               Converter={StaticResource UrlToImage}}"
                                           Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,20,0">
                                    <TextBlock Text="{Binding LastCompletedTitle}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="Completado"
                                               FontSize="11" Foreground="{DynamicResource AccentColor}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,36"
                           Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── ÚLTIMOS COMPLETADOS (10 portadas) ── -->
                <StackPanel Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="ÚLTIMOS COMPLETADOS"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding RecentHistory}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PublicHistoryItemViewModel}">
                                <StackPanel Width="130" Margin="0,0,18,24">
                                    <Border Height="185" CornerRadius="6" ClipToBounds="True"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Margin="0,0,0,8">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" ShadowDepth="0"
                                                              BlurRadius="12" Opacity="0.1"/>
                                        </Border.Effect>
                                        <Image Source="{Binding CoverUrl, Converter={StaticResource UrlToImage}}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="11" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── LISTA COMPLETA (expandible) ── -->
                    <StackPanel Visibility="{Binding HasFullHistory, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,8,0,0">

                        <!-- Toggle -->
                        <Button HorizontalAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="0,10,0,10"
                                Command="{Binding ToggleHistoryCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ToggleLabel}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>
                        </Button>

                        <!-- Lista completa (misma plantilla que recientes) -->
                        <ItemsControl ItemsSource="{Binding FullHistory}"
                                      Margin="0,8,0,0"
                                      Visibility="{Binding IsHistoryExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PublicHistoryItemViewModel}">
                                    <StackPanel Width="130" Margin="0,0,18,24">
                                        <Border Height="185" CornerRadius="6" ClipToBounds="True"
                                                Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                                Margin="0,0,0,8">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" ShadowDepth="0"
                                                                  BlurRadius="12" Opacity="0.1"/>
                                            </Border.Effect>
                                            <Image Source="{Binding CoverUrl, Converter={StaticResource UrlToImage}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- Empty history -->
                <TextBlock Text="Este usuario aún no ha completado ningún manga."
                           Style="{StaticResource CaptionText}"
                           Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
