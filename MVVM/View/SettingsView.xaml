<UserControl x:Class="Hakufu.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,24,40,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,24,0"/>
                <TextBlock Grid.Column="1" Text="AJUSTES"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ BODY ═══ -->
        <ScrollViewer x:Name="sv" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MinHeight="{Binding ViewportHeight, ElementName=sv}">
            <StackPanel Width="560" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="40,40,40,40">

                <!-- ── TEMA ── -->
                <Border Style="{StaticResource Card}" Padding="0"
                        Margin="0,0,0,20" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Visual preview -->
                        <Grid Grid.Row="0" Height="88">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F2F2F2">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Aa"
                                               FontSize="24" FontWeight="Medium"
                                               Foreground="#1A1A1A"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="CLARO"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="#999999"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#111111">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Aa"
                                               FontSize="24" FontWeight="Medium"
                                               Foreground="#F0F0F0"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="OSCURO"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="#555555"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Toggle row -->
                        <Border Grid.Row="1"
                                Padding="24,18"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Tema oscuro"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="Cambia entre modo claro y oscuro"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1"
                                              Style="{StaticResource ThemeToggle}"
                                              IsChecked="{Binding IsDarkTheme}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── ESPACIO DE DISCO ── -->
                <Border Style="{StaticResource Card}" Padding="24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Espacio de disco usado"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,16"/>

                        <!-- Aplicación -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Aplicación"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AppSizeText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,10"/>

                        <!-- Archivos manga del usuario -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Mangas"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Archivos PDF / CBR / CBZ en tu equipo"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MangasSizeText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,10"/>

                        <!-- Caché local Hakufu -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Caché de Hakufu"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Portadas y datos guardados en %APPDATA%"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CachesSizeText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Button -->
                        <Button Style="{StaticResource GhostButton}"
                                Content="Gestionar espacio"
                                HorizontalAlignment="Left"
                                Padding="16,9"
                                Command="{Binding OpenStorageManagerCommand}"/>
                    </StackPanel>
                </Border>

                <!-- ── ACERCA DE ── -->
                <Border Style="{StaticResource Card}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Acerca de"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Hakufu"
                                       FontSize="22" FontWeight="Black"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Gestor de mangas offline"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,16"/>
                            <TextBlock Text="Versión 0.4.5"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text=".NET 10 · WPF · Windows"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="por Daniel Poza Rivera"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="H"
                                   FontSize="72" FontWeight="Black"
                                   Foreground="{DynamicResource DividerBrush}"
                                   VerticalAlignment="Center"
                                   Margin="24,0,0,0"/>
                    </Grid>
                </Border>

            </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
