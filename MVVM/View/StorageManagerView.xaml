<UserControl x:Class="Hakufu.MVVM.View.StorageManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel MinWidth="480">

        <!-- Header -->
        <TextBlock Text="Gestionar espacio"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Datos almacenados por Hakufu en tu equipo"
                   FontSize="12"
                   Foreground="{DynamicResource TextMuted}"
                   Margin="0,0,0,20"/>

        <!-- ── LIMPIAR ESPACIO ── -->
        <Border BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16" Margin="0,0,0,16">
            <StackPanel>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Limpiar espacio"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding MigrateHintText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,3,12,0"/>
                    </StackPanel>
                    <!-- Limpiar button — visible when no confirm/progress shown -->
                    <Button Grid.Column="1"
                            Content="Limpiar espacio"
                            Padding="14,8"
                            VerticalAlignment="Center"
                            Command="{Binding RequestMigrateCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasExternalMangas}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ShowMigrateConfirm}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMigrating}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Confirm panel -->
                <Border Background="{DynamicResource SidebarBackground}"
                        CornerRadius="6" Padding="12,10"
                        Margin="0,4,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowMigrateConfirm}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="¿Confirmar limpieza?"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10">
                            Los archivos se copiarán a la biblioteca local y luego se eliminarán de sus ubicaciones originales. Esta acción no se puede deshacer.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource GhostButton}"
                                    Content="Cancelar"
                                    Padding="14,7"
                                    Margin="0,0,8,0"
                                    Command="{Binding CancelMigrateCommand}"/>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="Sí, limpiar"
                                    Padding="14,7"
                                    Command="{Binding ConfirmMigrateCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Progress panel -->
                <Border Background="{DynamicResource SidebarBackground}"
                        CornerRadius="6" Padding="12,10"
                        Margin="0,4,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMigrating}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳ "
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Text="{Binding MigrateProgressText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Result panel (after migration, not migrating) -->
                <Border Background="{DynamicResource SidebarBackground}"
                        CornerRadius="6" Padding="12,10"
                        Margin="0,4,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMigrating}"        Value="False"/>
                                        <Condition Binding="{Binding MigrateProgressText}" Value=""/>
                                    </MultiDataTrigger.Conditions>
                                    <!-- empty text = initial state, keep hidden -->
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding MigrateProgressText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMigrating}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding MigrateProgressText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Border>

        <!-- ── APPDATA FILE LIST ── -->
        <Border BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1" CornerRadius="8"
                Margin="0,0,0,12">
            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="18,11,18,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SizeText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="16,0,20,0"/>
                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Border Grid.Row="1"
                                        Height="1"
                                        Background="{DynamicResource DividerBrush}"
                                        Margin="18,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <TextBlock Text="{Binding StatusText}"
                   FontSize="11"
                   Foreground="{DynamicResource TextMuted}"
                   Margin="0,0,0,20"/>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource GhostButton}"
                    Content="Cerrar"
                    Padding="20,10"
                    Margin="0,0,12,0"
                    Command="{Binding CloseCommand}"/>
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Eliminar seleccionados"
                    Padding="20,10"
                    IsEnabled="{Binding HasSelection}"
                    Command="{Binding DeleteSelectedCommand}"/>
        </StackPanel>

    </StackPanel>
</UserControl>
