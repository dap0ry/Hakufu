<UserControl x:Class="Hakufu.MVVM.View.StoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ BARRA DE NAVEGACIÓN ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Volver al inicio de la app -->
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Padding="12,7"
                        Margin="0,0,8,0"/>

                <!-- Controles del navegador -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button x:Name="BtnBack"
                            Style="{StaticResource IconButton}"
                            Content="◀" FontSize="10"
                            ToolTip="Atrás"
                            Width="28" Height="28"
                            Click="BtnBack_Click"/>
                    <Button x:Name="BtnForward"
                            Style="{StaticResource IconButton}"
                            Content="▶" FontSize="10"
                            ToolTip="Adelante"
                            Width="28" Height="28"
                            Click="BtnForward_Click"/>
                    <Button x:Name="BtnRefresh"
                            Style="{StaticResource IconButton}"
                            Content="↺" FontSize="15"
                            ToolTip="Recargar"
                            Width="28" Height="28"
                            Click="BtnRefresh_Click"/>
                </StackPanel>

                <!-- Barra de direcciones -->
                <TextBox Grid.Column="2"
                         Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Height="30">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding NavigateCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </Grid>
        </Border>

        <!-- ═══ BARRA DE FAVORITOS ═══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <ItemsControl ItemsSource="{Binding Bookmarks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource GhostButton}"
                                Content="{Binding Label}"
                                CommandParameter="{Binding Url}"
                                Command="{Binding DataContext.NavigateToUrlCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,4,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ═══ NAVEGADOR EMBEBIDO ═══ -->
        <wv2:WebView2 Grid.Row="2" x:Name="WebBrowser"/>

    </Grid>
</UserControl>
