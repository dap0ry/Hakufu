<UserControl x:Class="Hakufu.MVVM.View.StoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,24,40,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,24,0"/>
                <TextBlock Grid.Column="1" Text="TIENDA"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ BODY ═══ -->
        <Grid Grid.Row="1">

            <!-- Catálogo vacío -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="—"
                           FontSize="32"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="No hay manga disponible por el momento"
                           FontSize="13"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Lista de manga -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Items}"
                              Margin="40,32,40,40">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Portada -->
                                    <Border Grid.Column="0"
                                            Width="96" Height="136"
                                            CornerRadius="4"
                                            Background="{DynamicResource DividerBrush}"
                                            ClipToBounds="True"
                                            VerticalAlignment="Top">
                                        <Image Source="{Binding CoverUrl}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="2">

                                        <!-- Título + autor -->
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding Author}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,0,0,10"/>

                                        <!-- Descripción -->
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="60"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"/>

                                        <!-- Tags -->
                                        <TextBlock Text="{Binding TagsText}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentColor}"
                                                   Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}"
                                                   Margin="0,0,0,6"/>

                                        <!-- Meta (páginas / tamaño) -->
                                        <TextBlock Text="{Binding MetaText}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Visibility="{Binding HasMeta, Converter={StaticResource BoolToVisibility}}"
                                                   Margin="0,0,0,0"/>

                                        <!-- Volúmenes / links de descarga -->
                                        <ItemsControl ItemsSource="{Binding Volumes}"
                                                      Margin="0,14,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource DividerBrush}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="0,10,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Label}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Content="Descargar"
                                                                    Padding="16,7"
                                                                    Command="{Binding OpenLinkCommand}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
