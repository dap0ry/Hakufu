<UserControl x:Class="Hakufu.MVVM.View.SyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,22,40,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding BackCommand}"
                        Margin="0,0,24,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="SINCRONIZACIÓN"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="Datos locales ↔ servidor"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="SESIÓN ACTIVA"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding Username}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentColor}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BODY ═══ -->
        <ScrollViewer Grid.Row="1"
                      Padding="40,36,40,40"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="620" HorizontalAlignment="Left">

                <!-- ── FOTO DE PERFIL ── -->
                <TextBlock Text="FOTO DE PERFIL"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,12"/>

                <Border CornerRadius="10" Padding="28,22" Margin="0,0,0,32"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Círculo avatar -->
                        <Border Width="72" Height="72" CornerRadius="36" ClipToBounds="True"
                                Background="{DynamicResource AccentColor}">
                            <Grid>
                                <!-- Foto (si existe) -->
                                <Image Source="{Binding AvatarUrl, Converter={StaticResource UrlToImage}}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibility}}"/>
                                <!-- Inicial (si no hay foto) -->
                                <TextBlock Text="{Binding AvatarInitial}"
                                           FontSize="26" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                        </Border>

                        <!-- Info + botón -->
                        <StackPanel Margin="22,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Username}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,4"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,12">
                                <Run Text="Máx. 2 MB · JPG, PNG o GIF"/>
                            </TextBlock>
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="Cambiar foto de perfil"
                                    HorizontalAlignment="Left" Padding="18,9"
                                    Command="{Binding UploadAvatarCommand}"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Divisor -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,32"/>

                <!-- Progreso (solo cuando está ocupado) -->
                <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,24"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     Foreground="{DynamicResource AccentColor}"
                                     Background="Transparent"
                                     Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <!-- Mensaje de estado (éxito / error) -->
                <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,24"
                        BorderThickness="1"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"   Value="{DynamicResource CardBackground}"/>
                            <Setter Property="BorderBrush"  Value="{DynamicResource CardBorder}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3EA76A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="BorderBrush" Value="#E05C5C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- ── SUBIR DATOS LOCALES ── -->
                <TextBlock Text="SUBIR DATOS LOCALES"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,12"/>

                <Border CornerRadius="10" Padding="28,24" Margin="0,0,0,32"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Subir biblioteca al servidor"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20">
                            Sube tus colecciones, progreso de lectura e historial al servidor. Las portadas de cada manga se suben a Cloudinary y quedan visibles en tu perfil público. Esto <Run FontWeight="SemiBold">reemplaza</Run> los datos que haya en el servidor.
                        </TextBlock>

                        <!-- Botón normal -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Subir datos"
                                HorizontalAlignment="Left" Padding="22,10"
                                Command="{Binding RequestUploadCommand}"
                                Visibility="{Binding IsIdle, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Confirmación -->
                        <StackPanel Visibility="{Binding IsConfirmingUpload, Converter={StaticResource BoolToVisibility}}">
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,14"
                                    Background="#1AE0A640" BorderBrush="#E0A640" BorderThickness="1">
                                <TextBlock FontSize="12" Foreground="#E0A640" TextWrapping="Wrap">
                                    ¿Seguro? Esto reemplazará todos los datos en el servidor con tu biblioteca actual.
                                </TextBlock>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Sí, subir ahora"
                                        Padding="22,10" Margin="0,0,10,0"
                                        Command="{Binding ConfirmUploadCommand}"/>
                                <Button Style="{StaticResource GhostButton}"
                                        Content="Cancelar"
                                        Padding="22,10"
                                        Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Divisor -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,0,0,32"/>

                <!-- ── DESCARGAR DATOS DEL SERVIDOR ── -->
                <TextBlock Text="DESCARGAR DATOS DEL SERVIDOR"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,12"/>

                <Border CornerRadius="10" Padding="28,24"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Restaurar datos del servidor"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20">
                            Descarga el tiempo de lectura, historial y las URLs de portadas desde el servidor. Los archivos de manga <Run FontWeight="SemiBold">no se descargan</Run>. Útil para recuperar estadísticas en una instalación nueva.
                        </TextBlock>

                        <!-- Botón normal -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Descargar datos"
                                HorizontalAlignment="Left" Padding="22,10"
                                Command="{Binding RequestDownloadCommand}"
                                Visibility="{Binding IsIdle, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Confirmación -->
                        <StackPanel Visibility="{Binding IsConfirmingDownload, Converter={StaticResource BoolToVisibility}}">
                            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,14"
                                    Background="#1AE0A640" BorderBrush="#E0A640" BorderThickness="1">
                                <TextBlock FontSize="12" Foreground="#E0A640" TextWrapping="Wrap">
                                    ¿Seguro? El tiempo de lectura y las portadas locales se actualizarán con los datos del servidor.
                                </TextBlock>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Sí, descargar"
                                        Padding="22,10" Margin="0,0,10,0"
                                        Command="{Binding ConfirmDownloadCommand}"/>
                                <Button Style="{StaticResource GhostButton}"
                                        Content="Cancelar"
                                        Padding="22,10"
                                        Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Divisor -->
                <Rectangle Height="1" Fill="{DynamicResource DividerBrush}" Margin="0,32,0,32"/>

                <!-- ── CERRAR SESIÓN ── -->
                <TextBlock Text="CUENTA"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,12"/>

                <Border CornerRadius="10" Padding="28,24"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="14" Opacity="0.07"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Cerrar sesión"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20">
                            Cierra la sesión activa en este dispositivo. Los datos locales no se eliminan.
                        </TextBlock>
                        <Button Style="{StaticResource GhostButton}"
                                Content="Cerrar sesión"
                                HorizontalAlignment="Left" Padding="22,10"
                                Command="{Binding LogoutCommand}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
