<UserControl x:Class="Hakufu.MVVM.View.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="40,24,40,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource GhostButton}"
                        Content="← Inicio"
                        Command="{Binding GoBackCommand}"
                        Margin="0,0,24,0"/>
                <TextBlock Grid.Column="1" Text="ACTUALIZACIONES"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="520" HorizontalAlignment="Center"
                        Margin="0,48,0,56">

                <!-- Título -->
                <TextBlock Text="Hakufu"
                           FontSize="28" FontWeight="Black"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Sistema de actualizaciones"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,32"/>

                <!-- Version cards -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}"
                            Padding="20,18" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="VERSIÓN ACTUAL"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CurrentVersion}"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}"
                            Padding="20,18" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="ÚLTIMA VERSIÓN"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="—"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Visibility="{Binding IsChecking,
                                           Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding LatestVersion}"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource AccentColor}"
                                       Visibility="{Binding IsChecking,
                                           Converter={StaticResource InverseBoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Indeterminate progress while checking -->
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Margin="0,24,0,0"
                             Foreground="{DynamicResource ProgressFill}"
                             Background="{DynamicResource ProgressTrack}"
                             BorderThickness="0"
                             Visibility="{Binding IsChecking,
                                 Converter={StaticResource BoolToVisibility}}"/>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,24,0,0"
                           Visibility="{Binding IsChecking,
                               Converter={StaticResource InverseBoolToVisibility}}"/>

                <!-- Changelog — only when update available -->
                <Border Style="{StaticResource Card}"
                        Padding="24,20"
                        Margin="0,24,0,0"
                        Visibility="{Binding IsUpdateAvailable,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="NOVEDADES"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Changelog}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Download progress bar -->
                <StackPanel Margin="0,24,0,0"
                            Visibility="{Binding IsDownloading,
                                Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:F0}%}"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding DownloadProgress, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Height="4"
                                 Foreground="{DynamicResource ProgressFill}"
                                 Background="{DynamicResource ProgressTrack}"
                                 BorderThickness="0"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,32,0,0">
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Descargar e instalar"
                            Padding="24,11"
                            Command="{Binding DownloadCommand}"
                            Visibility="{Binding IsUpdateAvailable,
                                Converter={StaticResource BoolToVisibility}}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="Comprobar de nuevo"
                            Padding="24,11"
                            Command="{Binding CheckAgainCommand}"
                            Visibility="{Binding IsUpdateAvailable,
                                Converter={StaticResource InverseBoolToVisibility}}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
