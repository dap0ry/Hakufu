<Window x:Class="Hakufu.MVVM.View.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Hakufu — Actualizaciones"
        Height="560" Width="680"
        MinHeight="420" MinWidth="500"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        StateChanged="Window_StateChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource WindowBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ACTUALIZACIONES"
                           Foreground="{DynamicResource TitleBarForeground}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"
                           IsHitTestVisible="False"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Width="46" Height="40"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_Click">
                        <Path Data="M 3,8 L 13,8"
                              Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1.3" Width="16" Height="16" Stretch="None"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Width="46" Height="40"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click">
                        <Path Data="M 3,3 L 13,13 M 13,3 L 3,13"
                              Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1.3" Width="16" Height="16" Stretch="None"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="520" HorizontalAlignment="Center"
                        Margin="0,40,0,48">

                <!-- Header -->
                <TextBlock Text="SISTEMA DE ACTUALIZACIONES"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Hakufu"
                           FontSize="28" FontWeight="Black"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimary}"/>

                <!-- Version cards -->
                <Grid Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}"
                            Padding="20,18" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="VERSIÓN ACTUAL"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CurrentVersion}"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}"
                            Padding="20,18" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="ÚLTIMA VERSIÓN"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="—"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextMuted}"
                                       Visibility="{Binding IsChecking,
                                           Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding LatestVersion}"
                                       FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource AccentColor}"
                                       Visibility="{Binding IsChecking,
                                           Converter={StaticResource InverseBoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Indeterminate progress while checking -->
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Margin="0,20,0,0"
                             Foreground="{DynamicResource ProgressFill}"
                             Background="{DynamicResource ProgressTrack}"
                             BorderThickness="0"
                             Visibility="{Binding IsChecking,
                                 Converter={StaticResource BoolToVisibility}}"/>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,20,0,0"
                           Visibility="{Binding IsChecking,
                               Converter={StaticResource InverseBoolToVisibility}}"/>

                <!-- Changelog — only when update available -->
                <Border Style="{StaticResource Card}"
                        Padding="24,20"
                        Margin="0,20,0,0"
                        Visibility="{Binding IsUpdateAvailable,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="NOVEDADES"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Changelog}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Download progress bar — only while downloading -->
                <StackPanel Margin="0,20,0,0"
                            Visibility="{Binding IsDownloading,
                                Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:F0}%}"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding DownloadProgress, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Height="4"
                                 Foreground="{DynamicResource ProgressFill}"
                                 Background="{DynamicResource ProgressTrack}"
                                 BorderThickness="0"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,28,0,0">
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Descargar e instalar"
                            Padding="24,11"
                            Command="{Binding DownloadCommand}"
                            Visibility="{Binding IsUpdateAvailable,
                                Converter={StaticResource BoolToVisibility}}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="Comprobar de nuevo"
                            Padding="24,11"
                            Command="{Binding CheckAgainCommand}"
                            Visibility="{Binding IsUpdateAvailable,
                                Converter={StaticResource InverseBoolToVisibility}}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
