<Window x:Class="Hakufu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Hakufu.MVVM.ViewModel"
        Title="Hakufu" Height="780" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStyle="None"
        Background="{DynamicResource AppBackground}"
        StateChanged="Window_StateChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TITLE BAR ═══════════ -->
        <Border x:Name="TitleBarBorder"
                Grid.Row="0"
                Height="40"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource WindowBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="HAKUFU"
                           Foreground="{DynamicResource TitleBarForeground}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           IsHitTestVisible="False"/>

                <!-- Window controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Width="46" Height="40"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_Click">
                        <Path Data="M 3,8 L 13,8" Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1.3" Width="16" Height="16" Stretch="None"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Width="46" Height="40"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeButton_Click">
                        <Path Data="M 3,3 L 13,3 L 13,13 L 3,13 Z"
                              Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1.3" Width="16" Height="16" Fill="Transparent" Stretch="None"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            Width="46" Height="40"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click">
                        <Path Data="M 3,3 L 13,13 M 13,3 L 3,13"
                              Stroke="{DynamicResource TitleBarForeground}"
                              StrokeThickness="1.3" Width="16" Height="16" Stretch="None"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ MAIN AREA ═══════════ -->
        <Grid Grid.Row="1">

            <!-- Page content -->
            <Border Background="{DynamicResource AppBackground}" ClipToBounds="True">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>

            <!-- Modal overlay -->
            <Grid Panel.ZIndex="100"
                  Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibility}}">
                <Rectangle Fill="{DynamicResource OverlayBackground}"
                           MouseDown="Overlay_MouseDown"/>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource Card}"
                        MinWidth="420" MaxWidth="560"
                        Padding="32">
                    <ContentControl Content="{Binding ModalContent}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
